        },
        {
          "info": {
            "name": "Delete a Group of Contacts",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api-app2.simpletexting.com/v2/api/contacts-batch/batch-delete"
          },
          "docs": "Delete a Group of Contacts"
        }
      ]
    },
