          "docs": "Submits an asynchronous batch update task for a group of contacts."
        },
        {
          "info": {
            "name": "Get the Result of a Batch Update Task",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api-app2.simpletexting.com/v2/api/contacts-batch/batch-update/{taskId}"
